# Anthropic (for r0x Agent chat)
ANTHROPIC_API_KEY=your-anthropic-api-key

# x402 / Skill API
ADDRESS=0x101Cd32b9bEEE93845Ead7Bc604a5F1873330acf
NETWORK=eip155:4663

# Robinhood Chain RPC (defaults to the public mainnet RPC if unset)
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Self-hosted x402 facilitator gas wallet
# No third-party facilitator (Coinbase CDP, PayAI, etc.) supports Robinhood Chain yet,
# so this server verifies AND settles its own x402 payments in-process. This wallet
# pays gas for settlement transactions (transferWithAuthorization calls) — fund it with
# a small amount of ETH on Robinhood Chain (chain ID 4663). Keep this key secret.
EVM_PRIVATE_KEY=0xyour-gas-wallet-private-key

# Upstash Redis (optional — powers the $100 "unlimited access" API key store)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
